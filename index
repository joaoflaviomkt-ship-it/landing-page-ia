.feature{
background:var(--card);
padding:20px;
border-radius:12px;
border:1px solid var(--line);
}

.offer{
background:linear-gradient(135deg, rgba(109,94,252,.15), rgba(0,212,255,.10));
padding:30px;
border-radius:20px;
border:1px solid var(--line);
text-align:center;
}

.price{
