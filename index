font-weight:bold;
}

.faq{
margin-top:40px;
}

details{
margin-bottom:10px;
background:var(--card);
padding:15px;
border-radius:10px;
}

footer{
margin-top:60px;
text-align:center;
color:var(--muted);
}

@media (max-width:900px){

.hero-grid{
grid-template-columns:1fr;
